// GasTubos — Prisma Schema
// PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Rol {
  ADMIN
  SUPERVISOR
  OPERADOR
  REPARTIDOR
}

enum EstadoTubo {
  DISPONIBLE
  CARGADO
  VACIO
  ENTREGADO
  ALQUILADO
  VENDIDO
  RESERVADO
  PERDIDO
  DEVUELTO
  EN_REVISION
}

enum TipoCliente {
  EMPRESA
  PYME
  PARTICULAR
}

enum TipoPropietario {
  PROPIO
  CLIENTE
}

enum TipoOperacion {
  ENTREGA_SIMPLE   // entrega sin alquiler formal
  ALQUILER         // genera registro en Alquiler
  VENTA            // genera registro en Venta
}

enum EstadoAlquiler {
  ACTIVO
  VENCIDO
  FINALIZADO
  CANCELADO
}

enum TipoGas {
  CO2
  OXIGENO
  ARGON
  NITROGENO
  AIRE_COMPRIMIDO
  MEZCLA_CO2_ARGON
  ACETILENO
}

enum UnidadGas {
  KG
  M3
}

// ─── USUARIOS ─────────────────────────────────────────────────────────────────

model Usuario {
  id          String   @id @default(cuid())
  username    String   @unique
  email       String   @unique
  passwordHash String
  nombre      String
  rol         Rol
  avatar      String?  // URL o base64 de la foto
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relaciones
  auditoria          Auditoria[]
  entregasCreadas    Entrega[]   @relation("EntregaCreadaPor")
  entregasRepartidor Entrega[]   @relation("EntregaRepartidor")
  cargas             Carga[]

  @@map("usuarios")
}

// ─── CLIENTES ─────────────────────────────────────────────────────────────────

model Cliente {
  id          String      @id @default(cuid())
  nombre      String
  ruc         String      @unique  // RUC o CI
  telefono    String?
  direccion   String?
  contacto    String?     // nombre del contacto principal
  tipo        TipoCliente @default(EMPRESA)
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tubos       Tubo[]      // tubos actualmente asignados
  alquileres  Alquiler[]
  ventas      Venta[]
  entregas    Entrega[]
  recambios   Recambio[]

  @@map("clientes")
}

// ─── TUBOS ────────────────────────────────────────────────────────────────────

model Tubo {
  id              String          @id  // TUBO-000001, generado en app
  serie           String          @unique
  gas             String          // CO2, Oxígeno, Argón, etc.
  capacidadLitros Int?
  capacidadKg     Decimal?        @db.Decimal(5, 2)
  talla           String          // T50, T10, T8
  pesoKg          Decimal?        @db.Decimal(8, 2)
  estado          EstadoTubo      @default(DISPONIBLE)
  propietario     TipoPropietario @default(PROPIO)
  fechaCompra     DateTime?
  ubicacion       String?
  observaciones   String?
  activo          Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // cliente actualmente asignado (null si está en depósito)
  clienteId       String?
  cliente         Cliente?        @relation(fields: [clienteId], references: [id])

  // Si es tubo de cliente, qué cliente es el dueño
  propietarioClienteId String?

  // camion asignado (null si está en depósito o entregado)
  camionId        String?
  camion          Camion?         @relation(fields: [camionId], references: [id])

  // relaciones
  auditoria              Auditoria[]
  detallesEntrega        DetalleEntrega[]
  alquileres             Alquiler[]
  ventas                 Venta[]
  cargas                 Carga[]
  recambiosComoEntregado Recambio[]       @relation("TuboRetornado")

  @@map("tubos")
}

// ─── ENTREGAS ─────────────────────────────────────────────────────────────────

model Entrega {
  id              String        @id @default(cuid())
  numero          String        @unique  // E-2025-001, generado en app
  clienteId       String
  cliente         Cliente       @relation(fields: [clienteId], references: [id])
  direccionEntrega String
  latitud         Float?
  longitud        Float?
  tipoOperacion   TipoOperacion
  fechaEntrega    DateTime      @default(now())
  observaciones   String?

  // quién creó el registro y quién repartió
  creadoPorId     String
  creadoPor       Usuario       @relation("EntregaCreadaPor", fields: [creadoPorId], references: [id])
  repartidorId    String?
  repartidor      Usuario?      @relation("EntregaRepartidor", fields: [repartidorId], references: [id])

  detalles        DetalleEntrega[]
  alquileres      Alquiler[]    // si tipoOperacion = ALQUILER
  recambios       Recambio[]
  costoDelivery   Decimal       @db.Decimal(10, 2) @default(0.00)
  confirmada      Boolean       @default(false)
  cancelada       Boolean       @default(false)
  motivoCancelacion String?
  metodoPago      String?
  montoRecibido   Decimal?      @db.Decimal(10, 2)

  createdAt       DateTime      @default(now())

  @@map("entregas")
}

model DetalleEntrega {
  id             String      @id @default(cuid())
  entregaId      String
  entrega        Entrega     @relation(fields: [entregaId], references: [id])
  tuboId         String
  tubo           Tubo        @relation(fields: [tuboId], references: [id])
  cantidadGas    Decimal     @db.Decimal(10, 3) @default(0.000)
  unidadGas      UnidadGas   @default(KG)
  precioUnitario Decimal     @db.Decimal(10, 2) @default(0.00)
  subtotal       Decimal     @db.Decimal(10, 2) @default(0.00)
  // Estado del tubo justo antes de la entrega — usado para revertir al cancelar.
  // Opcional para que filas viejas (pre-migración) sigan funcionando con fallback.
  estadoAnterior EstadoTubo?

  @@unique([entregaId, tuboId])
  @@map("detalles_entrega")
}

// ─── ALQUILERES ───────────────────────────────────────────────────────────────

model Alquiler {
  id            String         @id @default(cuid())
  numero        String         @unique  // AL-2025-001
  clienteId     String
  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  tuboId        String
  tubo          Tubo           @relation(fields: [tuboId], references: [id])
  entregaId     String?        // la entrega que originó este alquiler
  entrega       Entrega?       @relation(fields: [entregaId], references: [id])
  fechaInicio   DateTime
  fechaVencimiento DateTime
  fechaDevolucion DateTime?
  estado        EstadoAlquiler @default(ACTIVO)
  observaciones String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("alquileres")
}

// ─── VENTAS ───────────────────────────────────────────────────────────────────

model Venta {
  id            String   @id @default(cuid())
  numero        String   @unique  // V-2025-001
  clienteId     String
  cliente       Cliente  @relation(fields: [clienteId], references: [id])
  tuboId        String
  tubo          Tubo     @relation(fields: [tuboId], references: [id])
  fechaVenta    DateTime @default(now())
  referencia    String?  // nro. de factura, orden, etc.
  observaciones String?
  cancelada     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@map("ventas")
}

// ─── CARGAS ───────────────────────────────────────────────────────────────────

model Carga {
  id            Int       @id @default(autoincrement())
  numero        String    @unique  // CG-2026-001
  tuboId        String?
  tubo          Tubo?     @relation(fields: [tuboId], references: [id])
  tipoGas       TipoGas
  unidad        UnidadGas
  cantidad      Decimal   @db.Decimal(10, 3)
  fechaCarga    DateTime
  operadorId    String
  operador      Usuario   @relation(fields: [operadorId], references: [id])
  observaciones String?
  createdAt     DateTime  @default(now())

  @@index([tuboId])
  @@index([operadorId])
  @@index([fechaCarga])
  @@map("cargas")
}

// ─── AUDITORÍA ────────────────────────────────────────────────────────────────

model Auditoria {
  id             String     @id @default(cuid())
  tuboId         String
  tubo           Tubo       @relation(fields: [tuboId], references: [id])
  usuarioId      String
  usuario        Usuario    @relation(fields: [usuarioId], references: [id])
  accion         String     // "Cambio de estado", "Tubo creado", "QR impreso", etc.
  estadoAnterior EstadoTubo?
  estadoNuevo    EstadoTubo?
  observaciones  String?
  metadata       Json?      // datos extra (entregaId, alquilerId, etc.)
  createdAt      DateTime   @default(now())

  @@index([tuboId])
  @@index([usuarioId])
  @@index([createdAt])
  @@map("auditoria")
}

// ─── SISTEMA / CONTADORES Atómicos ────────────────────────────────────────────

model Counter {
  key   String @id // e.g., "E-2026", "AL-2026", "TUBO"
  value Int    @default(0)

  @@map("counters")
}

// ─── PRECIOS DE GAS ───────────────────────────────────────────────────────────

model PrecioGas {
  id             String    @id @default(cuid())
  gas            TipoGas   @unique // Ej: CO2, OXIGENO...
  unidad         UnidadGas // Ej: KG, M3
  precioUnitario Decimal   @db.Decimal(10, 2)
  actualizadoPor String?   // ID del Usuario administrador que lo editó
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  @@map("precios_gas")
}

model Recambio {
  id              String   @id @default(cuid())
  entregaId       String
  entrega         Entrega  @relation(fields: [entregaId], references: [id])
  tuboEntregadoId String
  tuboEntregado   Tubo     @relation("TuboRetornado", fields: [tuboEntregadoId], references: [id])
  clienteId       String
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  createdAt       DateTime @default(now())

  @@map("recambios")
}

// ─── CAMIONES ─────────────────────────────────────────────────────────────────

model Camion {
  id           String   @id @default(cuid())
  placa        String   @unique // Identificador/Placa/Patente
  capacidadMax Int
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tubos        Tubo[]

  @@map("camiones")
}

